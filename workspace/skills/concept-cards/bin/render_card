#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
WORKSPACE_DIR="$(cd "$SKILL_DIR/../.." && pwd)"
VENV_DIR="$WORKSPACE_DIR/.venv-shadow-mage"
PY="$VENV_DIR/bin/python"

if [ ! -x "$PY" ]; then
  python3 -m venv "$VENV_DIR"
  "$VENV_DIR/bin/pip" install Pillow >/dev/null
fi

exec "$PY" "$SKILL_DIR/scripts/render_card.py" "$@"
